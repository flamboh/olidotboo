---
import GithubGraph from "@/components/GithubGraph.astro";
import LastfmHeatmap from "@/components/LastfmHeatmap.astro";
import TopArtists from "@/components/TopArtists.astro";
import { email, experience, projects, socials } from "@/data";

const sections = [
  { id: "experience", label: "experience", entries: experience },
  { id: "projects", label: "projects", entries: projects },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="oliver boorstein — researcher, music lover, cs + data science @ uoregon"
    />
    <title>oliboo</title>
    <script is:inline>
      const stored = localStorage.getItem("theme");
      document.documentElement.dataset.theme =
        stored ??
        (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    </script>
  </head>
  <body>
    <main>
      <header class="masthead">
        <div>
          <h1>
            oliver boorstein <span class="pronouns">he/they</span>
          </h1>
          <p class="tagline">
            researcher, full-stack dev & track listener — cs + data science @
            uoregon
          </p>
          <button
            class="contact-line"
            type="button"
            data-copy-email
            data-email={email}
          >
            contact me: {email}
          </button>
        </div>
        <button type="button" data-theme-toggle aria-label="switch theme">
          [dark]
        </button>
      </header>

      <div class="content-grid">
        {
          sections.map((section) => (
            <section class={section.id} aria-labelledby={`${section.id}-label`}>
              <h2 class="label" id={`${section.id}-label`}>
                {section.label}
              </h2>
              {section.entries.map((entry) => (
                <article class="row">
                  <h3>
                    {entry.href ? (
                      <a
                        href={entry.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {entry.title}
                      </a>
                    ) : (
                      entry.title
                    )}
                    {entry.subtitle && (
                      <span class="subtitle">{entry.subtitle}</span>
                    )}
                  </h3>
                  <p class="description">{entry.description}</p>
                </article>
              ))}
            </section>
          ))
        }
      </div>

      <section aria-labelledby="activity-label">
        <h2 class="label" id="activity-label">activity</h2>
        <GithubGraph />
        <LastfmHeatmap />
        <TopArtists />
      </section>

      <footer>
        {
          socials.map((social) => (
            <a
              href={social.href}
              target={social.href.startsWith("/") ? undefined : "_blank"}
              rel="noopener noreferrer"
            >
              {social.label}
            </a>
          ))
        }
      </footer>
    </main>

    <script>
      const root = document.documentElement;
      const toggle = document.querySelector<HTMLButtonElement>(
        "[data-theme-toggle]",
      );

      function syncToggle() {
        if (!toggle) return;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        toggle.textContent = `[${next}]`;
        toggle.setAttribute("aria-label", `switch to ${next} theme`);
      }

      toggle?.addEventListener("click", () => {
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        localStorage.setItem("theme", next);
        syncToggle();
      });
      syncToggle();

      const copyButton =
        document.querySelector<HTMLButtonElement>("[data-copy-email]");
      const copyLabel = copyButton?.textContent ?? "";
      copyButton?.addEventListener("click", async () => {
        const address = copyButton.dataset.email ?? "";
        try {
          await navigator.clipboard.writeText(address);
          copyButton.textContent = "copied!";
        } catch {
          copyButton.textContent = "copy failed";
        }
        setTimeout(() => (copyButton.textContent = copyLabel), 1600);
      });
    </script>

    <style is:global>
      :root {
        color-scheme: light;
        --bg: #fafafa;
        --fg: #111111;
        --fg-secondary: #616161;
        --fg-tertiary: #9e9e9e;
        --border: #e2e2e2;
        --accent: #15803d;
      }

      html[data-theme="dark"] {
        color-scheme: dark;
        --bg: #000000;
        --fg: #ededed;
        --fg-secondary: #8f8f8f;
        --fg-tertiary: #5c5c5c;
        --border: #1e1e1e;
        --accent: #4ade80;
      }

      * {
        margin: 0;
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family:
          ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas,
          "Liberation Mono", monospace;
        font-size: 0.875rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        transition:
          background-color 0.2s ease,
          color 0.15s ease;
      }

      main {
        max-width: 760px;
        margin: 0 auto;
        padding: 4.5rem 1.25rem 5rem;
      }

      main > .masthead,
      main > .content-grid,
      main > section[aria-labelledby="activity-label"],
      main > footer {
        animation: page-enter 0.48s cubic-bezier(0.22, 0.8, 0.25, 1) both;
      }

      main > .content-grid {
        animation-delay: 0.05s;
      }

      main > section[aria-labelledby="activity-label"] {
        animation-delay: 0.1s;
      }

      main > footer {
        animation-delay: 0.15s;
      }

      @keyframes page-enter {
        from {
          opacity: 0;
          transform: translateY(7px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      a {
        color: var(--fg);
        text-decoration: underline;
        text-decoration-color: var(--fg-tertiary);
        text-underline-offset: 3px;
        transition: 0.15s ease;
        transition-property: color, text-decoration-color;
      }

      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }

      .masthead {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
      }

      h1 {
        font-size: 1rem;
        font-weight: 700;
      }

      .pronouns {
        font-size: 0.75rem;
        font-weight: 400;
        color: var(--fg-tertiary);
      }

      .tagline {
        margin-top: 0.375rem;
        color: var(--fg-secondary);
        text-wrap: balance;
      }

      .contact-line {
        display: block;
        margin-top: 0.125rem;
        color: var(--fg-tertiary);
        font-size: 0.8125rem;
      }

      button {
        font: inherit;
        color: var(--fg-secondary);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        transition: color 0.15s ease;
      }

      button:hover {
        color: var(--accent);
      }

      .content-grid {
        margin-top: 2.25rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2rem;
      }

      section[aria-labelledby="activity-label"] {
        margin-top: 3rem;
      }

      #activity-label {
        border-bottom: 1px solid var(--border);
      }

      .label {
        font-size: 0.6875rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--fg-tertiary);
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.5rem;
      }

      .row {
        margin-top: 1.375rem;
      }

      h3 {
        font-size: 0.875rem;
        font-weight: 600;
      }

      .subtitle {
        font-weight: 400;
        color: var(--fg-secondary);
      }

      .experience .subtitle {
        display: block;
      }

      .description {
        margin-top: 0.25rem;
        font-size: 0.8125rem;
        color: var(--fg-secondary);
        text-wrap: pretty;
      }

      footer {
        margin-top: 3.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        display: flex;
        flex-wrap: wrap;
        column-gap: 1.25rem;
        row-gap: 0.5rem;
        font-size: 0.8125rem;
      }

      footer a,
      footer button {
        color: var(--fg-secondary);
        text-decoration: none;
      }

      footer a:hover,
      footer button:hover {
        color: var(--accent);
      }

      @media (max-width: 640px) {
        main {
          padding-top: 2.5rem;
        }

        .content-grid {
          grid-template-columns: 1fr;
          gap: 3.5rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        main > .masthead,
        main > .content-grid,
        main > section[aria-labelledby="activity-label"],
        main > footer {
          animation: none;
        }
      }
    </style>
  </body>
</html>
